[run]
source = agentic_reliability_framework
omit = */tests/*,*/.venv/*,*/.eggs/*,*/site-packages/*

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    raise NotImplementedError
    if __name__ == .__main__.:
    logger.error
    logging.error
    logger.exception
    logging.exception
    warnings\.warn\(
